# Vercel ignore file — overrides .gitignore for deployment.
# IMPORTANT: api/index.mjs is a build artifact generated by scripts/build-server.mjs.
# It MUST be included in the deployment for the API serverless function to work.
# .gitignore excludes it (correct for git), but Vercel must include it.

node_modules
.turbo
.expo/
android/
ios/
.DS_Store
Thumbs.db
.idea
.claude/
coverage
test-results
*.lcov
.nyc_output
**/cypress/screenshots
**/cypress/videos
benchmarks/results/*.json
